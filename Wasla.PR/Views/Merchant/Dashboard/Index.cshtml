@model Wasla.PR.ViewModels.MerchantDashboardViewModel
@using Wasla.Models
@{
    ViewData["Title"] = "Dashboard";
}

@if (TempData["Success"] != null)
{
    <div style="padding:1rem 1.5rem; margin-bottom:1rem; background:#dcfce7; border-radius:8px; color:#166534; border:1px solid #86efac;">
        <i class="fas fa-check-circle"></i> @TempData["Success"]
    </div>
}

<div class="merchant-page-header">
    <div>
        <h1 class="merchant-page-title" data-i18n="welcome_back">مرحباً بعودتك!</h1>
        <p class="merchant-page-desc" data-i18n="dashboard_overview">ملخص أداء متجرك ولوجستياتك.</p>
    </div>
    <div>
        <a asp-controller="Merchant" asp-action="AddOrder" class="merchant-btn merchant-btn-primary">
            <i class="fas fa-plus"></i>
            <span data-i18n="nav_add_order">إضافة طلب</span>
        </a>
    </div>
</div>

@* Stats Row *@
<div class="merchant-stats-grid" id="dashboard-stats">
    <div class="merchant-stat-card">
        <div class="merchant-stat-icon" style="background:#eff6ff; color:#3b82f6;">
            <i class="fas fa-box"></i>
        </div>
        <div class="merchant-stat-content">
            <div class="merchant-stat-label" data-i18n="total_orders">إجمالي الطلبات</div>
            <div class="merchant-stat-value" id="stat-total">@Model.TotalOrdersCount</div>
        </div>
    </div>
    <div class="merchant-stat-card">
        <div class="merchant-stat-icon" style="background:#dcfce7; color:#10b981;">
            <i class="fas fa-check-circle"></i>
        </div>
        <div class="merchant-stat-content">
            <div class="merchant-stat-label" data-i18n="delivered">تم التوصيل</div>
            <div class="merchant-stat-value" id="stat-delivered">@Model.DeliveredOrdersCount</div>
        </div>
    </div>
    <div class="merchant-stat-card">
        <div class="merchant-stat-icon" style="background:#fee2e2; color:#ef4444;">
            <i class="fas fa-times-circle"></i>
        </div>
        <div class="merchant-stat-content">
            <div class="merchant-stat-label" data-i18n="rejected">مرفوض / مرتجع</div>
            <div class="merchant-stat-value" id="stat-rejected">@Model.RejectedOrdersCount</div>
        </div>
    </div>
    <div class="merchant-stat-card">
        <div class="merchant-stat-icon" style="background:#fef3c7; color:#f59e0b;">
            <i class="fas fa-clock"></i>
        </div>
        <div class="merchant-stat-content">
            <div class="merchant-stat-label" data-i18n="under_review">قيد المراجعة</div>
            <div class="merchant-stat-value" id="stat-review">@Model.UnderReviewOrdersCount</div>
        </div>
    </div>
</div>

@* Excel Upload / Download Template *@
<div class="merchant-actions-grid">
    <div class="merchant-action-card" id="excel-upload-card" style="cursor:pointer; position:relative;">
        <div class="merchant-stat-icon" style="background:#eff6ff; color:#3b82f6;">
            <i class="fas fa-cloud-upload-alt"></i>
        </div>
        <div style="display:flex; flex-direction:column; gap:0.5rem; flex:1;">
            <h3 data-i18n="upload_excel" style="font-size:1.1rem; font-weight:700; margin:0;">اسحب ملف Excel هنا أو انقر للاختيار</h3>
            <p data-i18n="upload_format" style="margin:0; font-size:0.85rem; color:var(--merchant-text-secondary);">الصيغ المدعومة: CSV / الحجم الأقصى: 10MB</p>
        </div>
        <button class="merchant-btn merchant-btn-primary" style="pointer-events:none;" data-browse-btn data-i18n="browse_files">Browse</button>
    </div>
    <div class="merchant-action-card merchant-action-card-solid">
        <div class="merchant-stat-icon" style="background:#dcfce7; color:#10b981;">
            <i class="fas fa-download"></i>
        </div>
        <div style="display:flex; flex-direction:column; gap:0.5rem; flex:1;">
            <h3 data-i18n="download_template" style="font-size:1.1rem; font-weight:700; margin:0;">تحميل النموذج</h3>
            <p data-i18n="download_desc" style="margin:0; font-size:0.85rem; color:var(--merchant-text-secondary);">استخدم هذا النموذج لضمان تنسيق الأعمدة الصحيح</p>
        </div>
        <button id="download-template-btn" class="merchant-btn merchant-btn-secondary" data-i18n="btn_download">تحميل</button>
    </div>
</div>

@* Recent Orders Table *@
<div class="merchant-card">
    <div class="merchant-card-header">
        <h3 class="merchant-card-title" data-i18n="recent_orders">أحدث الطلبات</h3>
        <a asp-controller="Merchant" asp-action="Orders"
           class="merchant-btn merchant-btn-secondary"
           style="padding:0.5rem 1rem; font-size:0.8rem;"
           data-i18n="view_all">عرض الكل</a>
    </div>
    <div class="merchant-table-container">
        <table class="merchant-table" id="recent-orders-table">
            <thead>
                <tr>
                    <th data-i18n="col_order_id">رقم الطلب</th>
                    <th data-i18n="col_customer">العميل</th>
                    <th data-i18n="col_amount">المبلغ</th>
                    <th data-i18n="col_status">الحالة</th>
                    <th data-i18n="col_date">التاريخ</th>
                </tr>
            </thead>
            <tbody id="recent-orders-tbody">
                @foreach (var order in Model.RecentOrders ?? new List<Order>())
                {
                    <tr>
                        <td><strong>#@order.Id</strong></td>
                        <td>@order.CustomerName</td>
                        <td>@order.TotalPrice.ToString("N2") E.G</td>
                        <td>
                            <span class="merchant-badge @GetStatusBadge(order.status.ToString())">
                                @GetStatusLabel(order.status.ToString())
                            </span>
                        </td>
                        <td>@order.CreatedAt.ToString("yyyy/MM/dd")</td>
                    </tr>
                }
                @if (!(Model.RecentOrders?.Any() ?? false))
                {
                    <tr>
                        <td colspan="5" style="text-align:center; color:var(--merchant-text-secondary); padding:2rem;">
                            <i class="fas fa-inbox" style="font-size:2rem; display:block; margin-bottom:0.5rem;"></i>
                            لا توجد طلبات حتى الآن
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@functions {
    string GetStatusBadge(string status) => status switch
    {
        "Delivered"           => "merchant-badge-success",
        "Created"             => "merchant-badge-primary",
        "PendingConfirmation" => "merchant-badge-warning",
        "OutForDelivery"      => "merchant-badge-primary",
        "Cancelled"           => "merchant-badge-danger",
        "FailedDelivery"      => "merchant-badge-danger",
        "Returned"            => "merchant-badge-danger",
        _                     => "merchant-badge-warning"
    };

    string GetStatusLabel(string status) => status switch
    {
        "Delivered"           => "تم التوصيل",
        "Created"             => "تم الإنشاء",
        "PendingConfirmation" => "قيد التأكيد",
        "Packed"              => "تم التغليف",
        "ReadyForPickup"      => "جاهز للاستلام",
        "PickedUp"            => "تم الاستلام",
        "InTransit"           => "في الطريق",
        "OutForDelivery"      => "خرج للتوصيل",
        "FailedDelivery"      => "فشل التوصيل",
        "Cancelled"           => "ملغي",
        "Returned"            => "مرتجع",
        _                     => status
    };
}

@section Scripts {
    <script src="https://cdn.sheetjs.com/xlsx-0.20.2/package/dist/xlsx.full.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="~/js/merchant.js"></script>
}
