@model Wasla.PR.ViewModels.Merchant.MerchantOrderDetailsViewModel
@{
    ViewData["Title"] = "Order Details";
}

<div class="merchant-page-header">
    <div>
        <h1 class="merchant-page-title">#@Model.Id</h1>
        <p class="merchant-page-desc">تفاصيل الطلب ومسار التتبع الكامل.</p>
    </div>
    <a asp-controller="Merchant" asp-action="Orders"
           class="merchant-btn merchant-btn-secondary">
        <i class="fas fa-arrow-right"></i>
        <span data-i18n="back">رجوع للطلبات</span>
    </a>
</div>

<div style="display:grid; grid-template-columns:2fr 1fr; gap:1.5rem; align-items:start;">

    @* Left: Customer & Package Info *@
    <div class="merchant-card" style="margin:0;">
        <h3 class="merchant-card-title" style="margin-bottom:1.5rem;">
            <i class="fas fa-user"></i> بيانات العميل
        </h3>
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem; margin-bottom:2rem;">
            <div>
                <label style="display:block; font-size:0.8rem; color:var(--merchant-text-secondary); margin-bottom:0.25rem;">الاسم</label>
                <div style="font-weight:600;">@Model.CustomerName</div>
            </div>
            <div>
                <label style="display:block; font-size:0.8rem; color:var(--merchant-text-secondary); margin-bottom:0.25rem;">الهاتف</label>
                <div style="font-weight:600;" dir="ltr">@Model.CustomerPhone</div>
            </div>
            <div style="grid-column:span 2;">
                <label style="display:block; font-size:0.8rem; color:var(--merchant-text-secondary); margin-bottom:0.25rem;">العنوان</label>
                <div style="font-weight:600;">@Model.CustomerAddress</div>
            </div>
            <div>
                <label style="display:block; font-size:0.8rem; color:var(--merchant-text-secondary); margin-bottom:0.25rem;">مدينة الإرسال</label>
                <div style="font-weight:600;">@(Model.CityFrom?.ToString() ?? "—")</div>
            </div>
            <div>
                <label style="display:block; font-size:0.8rem; color:var(--merchant-text-secondary); margin-bottom:0.25rem;">مدينة التوصيل</label>
                <div style="font-weight:600;">@Model.CityTo</div>
            </div>
        </div>

        <h3 class="merchant-card-title" style="margin-bottom:1.5rem; padding-top:1.5rem; border-top:1px solid var(--merchant-border);">
            <i class="fas fa-box"></i> معلومات الطرد
        </h3>
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
            <div>
                <label style="display:block; font-size:0.8rem; color:var(--merchant-text-secondary); margin-bottom:0.25rem;">المبلغ (COD)</label>
                <div style="font-weight:700; font-size:1.2rem; color:var(--primary);">
                    @Model.TotalPrice.ToString("N2") E.G
                </div>
            </div>
            <div>
                <label style="display:block; font-size:0.8rem; color:var(--merchant-text-secondary); margin-bottom:0.25rem;">طريقة الدفع</label>
                <div style="font-weight:600;">@Model.PaymentType</div>
            </div>
            <div>
                <label style="display:block; font-size:0.8rem; color:var(--merchant-text-secondary); margin-bottom:0.25rem;">تاريخ الإنشاء</label>
                <div style="font-weight:600;">@Model.CreatedAt.ToString("yyyy/MM/dd HH:mm")</div>
            </div>
            @if (Model.DeliveredAt.HasValue)
            {
                <div>
                    <label style="display:block; font-size:0.8rem; color:var(--merchant-text-secondary); margin-bottom:0.25rem;">تاريخ التوصيل</label>
                    <div style="font-weight:600;">@Model.DeliveredAt.Value.ToString("yyyy/MM/dd HH:mm")</div>
                </div>
            }
            <div>
                <label style="display:block; font-size:0.8rem; color:var(--merchant-text-secondary); margin-bottom:0.25rem;">قابل للكسر</label>
                <div>
                    @if (Model.IsBreakable)
                    {
                        <span class="merchant-badge merchant-badge-warning"><i class="fas fa-check"></i> نعم</span>
                    }
                    else
                    {
                        <span class="merchant-badge" style="background:#f1f5f9; color:#64748b;">لا</span>
                    }
                </div>
            </div>
            <div>
                <label style="display:block; font-size:0.8rem; color:var(--merchant-text-secondary); margin-bottom:0.25rem;">يتطلب مطالبة</label>
                <div>
                    @if (Model.IsClaimingRequired)
                    {
                        <span class="merchant-badge merchant-badge-warning"><i class="fas fa-check"></i> نعم</span>
                    }
                    else
                    {
                        <span class="merchant-badge" style="background:#f1f5f9; color:#64748b;">لا</span>
                    }
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.TrackingUuid))
        {
            <div style="margin-top:1.5rem; padding:1rem; background:var(--merchant-bg); border-radius:8px;">
                <label style="display:block; font-size:0.8rem; color:var(--merchant-text-secondary); margin-bottom:0.25rem;">
                    <i class="fas fa-barcode"></i> رمز التتبع
                </label>
                <code style="font-size:0.85rem; color:var(--primary); word-break:break-all;">@Model.TrackingUuid</code>
            </div>
        }
    </div>

    @* Right: Status, Courier Assignment & Tracking Timeline *@
    <div>
        @* 1. كارت الحالة الحالية *@
        <div class="merchant-card" style="margin:0; margin-bottom:1rem;">
            <h3 class="merchant-card-title" style="margin-bottom:1.5rem;">
                <i class="fas fa-truck"></i> الحالة الحالية
            </h3>
            <div style="margin-bottom:1.5rem;">
                <span class="merchant-badge @GetStatusBadge(Model.Status.ToString())"
                      style="font-size:1rem; padding:0.5rem 1rem;">
                    @GetStatusLabel(Model.Status.ToString())
                </span>
            </div>

            @if (!string.IsNullOrEmpty(Model.CurrentDriverName))
            {
                <div style="padding:0.75rem; background:var(--merchant-bg); border-radius:8px;">
                    <div style="font-size:0.8rem; color:var(--merchant-text-secondary); margin-bottom:0.25rem;">
                        <i class="fas fa-user-tie"></i> السائق المكلف
                    </div>
                    <div style="font-weight:600;">@Model.CurrentDriverName</div>
                </div>
            }
        </div>

        @* 2. كارت ترشيح وإسناد شركات الشحن المتوافقة *@
        @if (Model.Status.ToString() == "Created" && ViewBag.AvailableCouriers != null)
        {
            var couriers = ViewBag.AvailableCouriers as List<Wasla.BLL.Services.MerchantService.AvailableCourierDto>;
            <div class="merchant-card" style="margin:0; margin-bottom:1rem; border: 1px solid var(--primary);">
                <h3 class="merchant-card-title" style="margin-bottom:1rem; color: var(--primary);">
                    <i class="fas fa-magic"></i> ترشيح أفضل شركات الشحن
                </h3>
                <p style="font-size:0.8rem; color:var(--merchant-text-secondary); margin-bottom:1rem;">
                    تم ترتيب الشركات تلقائياً من الأرخص للأغلى بناءً على خط سير الشحنة من <strong>@Model.CityFrom</strong> إلى <strong>@Model.CityTo</strong>
                </p>

                @if (couriers != null && couriers.Any())
                {
                    <div style="display:flex; flex-direction:column; gap:0.75rem;">
                        @foreach (var courier in couriers)
                        {
                            <div style="display:flex; justify-content:space-between; align-items:center; padding:0.75rem; background:var(--merchant-bg); border-radius:8px; border:1px solid var(--merchant-border);">
                                <div>
                                    <div style="font-weight:600; font-size:0.95rem;">@courier.CompanyName</div>
                                    <div style="font-size:0.75rem; color:var(--merchant-text-secondary);">
                                        الكيلو الإضافي: @courier.ExtraKiloPrice.ToString("N2") ج.م
                                    </div>
                                </div>
                                <div style="text-align:left; display:flex; align-items:center; gap:1rem;">
                                    <div style="font-weight:700; color:var(--success); font-size:1.1rem;">
                                        @courier.BaseFee.ToString("N2") ج.م
                                    </div>
                                    <form asp-controller="Merchant" asp-action="AssignCourier" method="post" style="margin:0;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="orderId" value="@Model.Id" />
                                        <input type="hidden" name="companyId" value="@courier.CompanyId" />
                                        <button type="submit" class="merchant-btn merchant-btn-primary" style="padding:0.4rem 0.8rem; font-size:0.8rem;">
                                            إسناد الآن
                                        </button>
                                    </form>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div style="text-align:center; color:var(--merchant-text-secondary); font-size:0.85rem; padding:1rem 0;">
                        <i class="fas fa-exclamation-triangle" style="display:block; margin-bottom:0.5rem; color:var(--merchant-badge-warning);"></i>
                        لا توجد شركة شحن تغطي هذا الخط حالياً في كروت الأسعار.
                    </div>
                }
            </div>
        }
        else if (ViewBag.AssignedCompanyName != null)
        {
            <div class="merchant-card" style="margin:0; margin-bottom:1rem; background: #f0fdf4; border: 1px solid #bbf7d0;">
                <div style="font-size:0.8rem; color:#166534; margin-bottom:0.25rem;">
                    <i class="fas fa-building"></i> شركة الشحن المستلمة
                </div>
                <div style="font-weight:700; color:#14532d; font-size:1.05rem;">@ViewBag.AssignedCompanyName</div>
            </div>
        }

        @* 3. كارت مسار التتبع الكامل *@
        <div class="merchant-card" style="margin:0;">
            <h3 class="merchant-card-title" style="margin-bottom:1.5rem;">
                <i class="fas fa-route"></i> مسار التتبع
            </h3>

            @if (Model.TrackingHistory?.Any() == true)
            {
                <div style="position:relative; padding-right:1.5rem; border-right:2px solid var(--merchant-border); display:flex; flex-direction:column; gap:1.5rem;">
                    @foreach (var item in Model.TrackingHistory.OrderByDescending(t => t.Timestamp))
                    {
                        <div style="position:relative;">
                            <div style="position:absolute; right:-1.95rem; top:0; width:16px; height:16px; border-radius:50%; background:var(--primary); border:4px solid var(--merchant-bg);"></div>
                            <div style="font-weight:600; font-size:0.9rem;">@item.Status</div>
                            @if (!string.IsNullOrEmpty(item.Location))
                            {
                                <div style="font-size:0.8rem; color:var(--merchant-text-secondary);">
                                    <i class="fas fa-map-marker-alt"></i> @item.Location
                                </div>
                            }
                            <div style="font-size:0.75rem; color:var(--merchant-text-secondary); margin-top:0.25rem;">
                                @item.Timestamp.ToString("yyyy/MM/dd HH:mm")
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div style="text-align:center; color:var(--merchant-text-secondary); padding:1.5rem 0;">
                    <i class="fas fa-map-marked-alt" style="font-size:2rem; display:block; margin-bottom:0.5rem;"></i>
                    لا توجد بيانات تتبع حتى الآن
                </div>
            }
        </div>
    </div>
</div>

@functions {
    string GetStatusBadge(string status) => status switch
    {
        "Delivered" => "merchant-badge-success",
        "Created" => "merchant-badge-primary",
        "PendingConfirmation" => "merchant-badge-warning",
        "OutForDelivery" => "merchant-badge-primary",
        "Cancelled" => "merchant-badge-danger",
        "FailedDelivery" => "merchant-badge-danger",
        "Returned" => "merchant-badge-danger",
        _ => "merchant-badge-warning"
    };

    string GetStatusLabel(string status) => status switch
    {
        "Delivered" => "تم التوصيل",
        "Created" => "تم الإنشاء",
        "PendingConfirmation" => "قيد التأكيد",
        "Packed" => "تم التغليف",
        "ReadyForPickup" => "جاهز للاستلام",
        "PickedUp" => "تم الاستلام",
        "InTransit" => "في الطريق",
        "OutForDelivery" => "خرج للتوصيل",
        "FailedDelivery" => "فشل التوصيل",
        "Cancelled" => "ملغي",
        "Returned" => "مرتجع",
        _ => status
    };
}

@section Scripts {
    <script src="~/js/merchant.js"></script>
}