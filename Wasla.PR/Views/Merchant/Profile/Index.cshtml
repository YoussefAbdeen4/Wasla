@model Wasla.PR.ViewModels.Merchant.MerchantProfileViewModel
@{
    ViewData["Title"] = "Profile";
}

<div class="merchant-page-header">
    <div>
        <h1 class="merchant-page-title" data-i18n="nav_profile">Store Profile</h1>
        <p class="merchant-page-desc">Manage your public information and store details.</p>
    </div>
</div>

<div class="merchant-card" style="max-width:800px;">
    <div style="display:flex; align-items:center; gap:2rem; margin-bottom:2.5rem; padding-bottom:1.5rem; border-bottom:1px solid var(--merchant-border);">
        <div style="width:100px; height:100px; border-radius:50%; background:var(--primary-light); color:var(--primary); display:flex; align-items:center; justify-content:center; font-size:2.5rem; font-weight:700;">A</div>
        <div>
            <button class="merchant-btn merchant-btn-secondary" style="margin-bottom:0.5rem;"><i class="fas fa-camera"></i> Change Avatar</button>
            <p style="margin:0; font-size:0.8rem; color:var(--merchant-text-secondary);">Recommended size 500x500px, max 2MB.</p>
        </div>
    </div>

    <form asp-action="Profile" method="post">
        <input type="hidden" asp-for="Id" />
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
            <div class="merchant-form-group">
                <label class="merchant-form-label" data-i18n="col_name"><i class="fas fa-store"></i> Store Name</label>
                <input asp-for="StoreName" class="merchant-form-control" />
            </div>
            <div class="merchant-form-group">
                <label class="merchant-form-label"><i class="fas fa-id-card"></i> Commercial Record ID</label>
                <input asp-for="TaxNumber" class="merchant-form-control" />
            </div>
        </div>

        <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem; margin-top:1rem;">
            <div class="merchant-form-group">
                <label class="merchant-form-label"><i class="fas fa-user"></i> Merchant Name</label>
                <input asp-for="Name" class="merchant-form-control" />
            </div>
            <div class="merchant-form-group">
                <label class="merchant-form-label"><i class="fas fa-list"></i> Category</label>
                <input asp-for="Category" class="merchant-form-control" />
            </div>
        </div>

        <div style="display:flex; justify-content:flex-end; margin-top:1.5rem;">
            <button type="submit" class="merchant-btn merchant-btn-primary"><i class="fas fa-save"></i> Save</button>
        </div>
    </form>
</div>
