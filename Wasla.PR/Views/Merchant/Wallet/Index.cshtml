@model Wasla.PR.ViewModels.Merchant.WalletViewModel
@{
    ViewData["Title"] = "Wallet & Financials";
}

<div class="merchant-page-header">
    <div>
        <h1 class="merchant-page-title" data-i18n="nav_wallet">المحفظة والمدفوعات</h1>
        <p class="merchant-page-desc">تابع أرباحك واطلب السحب.</p>
    </div>
</div>

<div class="merchant-stats-grid">
    <div class="merchant-stat-card" style="background:linear-gradient(135deg, var(--merchant-primary), #1e3a8a); color:white; border:none;">
        <div class="merchant-stat-content">
            <div class="merchant-stat-label" style="color:#bfdbfe;" data-i18n="available_balance">الرصيد المتاح</div>
            <div class="merchant-stat-value" style="color:white;">
                @Model.AvailableBalance.ToString("N2") <span style="font-size:1rem;">E.G</span>
            </div>
        </div>
        <div style="width:48px; height:48px; border-radius:12px; background:rgba(255,255,255,0.2); display:flex; align-items:center; justify-content:center;">
            <i class="fas fa-wallet" style="font-size:1.5rem; color:white;"></i>
        </div>
    </div>

    <div class="merchant-stat-card">
        <div class="merchant-stat-icon" style="background:#fef3c7; color:#f59e0b;">
            <i class="fas fa-hourglass-half"></i>
        </div>
        <div class="merchant-stat-content">
            <div class="merchant-stat-label" data-i18n="pending_clearance">معلق للتحصيل</div>
            <div class="merchant-stat-value">
                @Model.PendingClearance.ToString("N2") <span style="font-size:1rem;">E.G</span>
            </div>
        </div>
    </div>

    <div class="merchant-stat-card">
        <div class="merchant-stat-icon" style="background:#dcfce7; color:#10b981;">
            <i class="fas fa-history"></i>
        </div>
        <div class="merchant-stat-content">
            <div class="merchant-stat-label" data-i18n="total_withdrawn">إجمالي المسحوب</div>
            <div class="merchant-stat-value">
                @Model.TotalWithdrawn.ToString("N2") <span style="font-size:1rem;">E.G</span>
            </div>
        </div>
    </div>

    <div class="merchant-stat-card">
        <div class="merchant-stat-icon" style="background:#e0e7ff; color:#3730a3;">
            <i class="fas fa-chart-line"></i>
        </div>
        <div class="merchant-stat-content">
            <div class="merchant-stat-label" data-i18n="total_revenue">إجمالي الإيرادات</div>
            <div class="merchant-stat-value">
                @Model.TotalRevenue.ToString("N2") <span style="font-size:1rem;">E.G</span>
            </div>
        </div>
    </div>
</div>

<div class="merchant-card">
    <div class="merchant-card-header">
        <h3 class="merchant-card-title"><i class="fas fa-list-ul"></i> أحدث المعاملات</h3>
        <button id="export-financial-btn" class="merchant-btn merchant-btn-secondary" style="padding:0.5rem 1rem; font-size:0.8rem;">
            <i class="fas fa-download"></i> تصدير PDF
        </button>
    </div>
    <div class="merchant-table-container">
        <table class="merchant-table" id="transactions-table">
            <thead>
                <tr>
                    <th>رقم المرجع</th>
                    <th>النوع</th>
                    <th>المبلغ</th>
                    <th>الحالة</th>
                    <th>التاريخ</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td colspan="5" style="text-align:center; color:var(--merchant-text-secondary); padding:2rem;">
                        <i class="fas fa-receipt" style="font-size:2rem; display:block; margin-bottom:0.5rem;"></i>
                        لا توجد معاملات مالية حتى الآن
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="~/js/merchant.js"></script>
}
