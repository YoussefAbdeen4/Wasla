<!DOCTYPE html>
<html lang="en" dir="ltr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wasla - @ViewData["Title"]</title>

    <link rel="stylesheet" href="~/css/splash.css">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>

<body class="public-body">
    <!-- Navbar -->
    <nav class="navbar">
        <div class="nav-actions">
            <a href="login.html" class="nav-link" data-i18n="nav_login">Login</a>
            <a href="signup-role.html" class="btn btn-primary splash-inline-1" data-i18n="nav_register">Sign Up</a>
            <div class="lang-switcher splash-inline-2">
                <button class="lang-btn" data-lang="en" data-i18n="lang_en">EN</button>
                <button class="lang-btn" data-lang="ar" data-i18n="lang_ar">العربيه</button>
            </div>
        </div>

        <div class="nav-links">
            <a asp-controller="Home" asp-action="Index" class="nav-link active" data-i18n="nav_home">Home</a>
            <a asp-controller="Home" asp-action="About" class="nav-link" data-i18n="nav_about">About</a>
            <a asp-controller="Home" asp-action="Contact" data-i18n="nav_contact">Contact</a>
        </div>

        <a asp-controller="Home" asp-action="Index" class="nav-logo">
            <span data-i18n="platform_name" class="splash-inline-3">Wasla</span>
            <i class="fa-solid fa-circle-info"></i>
        </a>
    </nav>

    @RenderBody()

    <!-- Footer -->
    <footer class="footer">
        <div class="footer-grid">
            <div class="footer-col">
                <a href="index.html" class="nav-logo splash-inline-24">
                    <span data-i18n="platform_name" class="splash-inline-3">Wasla</span>
                    <i class="fa-solid fa-circle-info"></i>
                </a>
                <p data-i18n="footer_desc" class="splash-inline-20">
                    One platform to manage
                    all shipping and delivery operations.
                </p>
            </div>
            <div class="footer-col">
                <h4 data-i18n="footer_links">Important Links</h4>
                <ul class="footer-links">
                    <li><a asp-controller="Home" asp-action="Index"  data-i18n="nav_home">Home</a></li>
                    <li><a asp-controller="Home" asp-action="About" data-i18n="nav_about">About</a></li>
                    <li><a asp-controller="Home" asp-action="Contact" data-i18n="nav_contact">Contact</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h4 data-i18n="footer_services">Our Services</h4>
                <ul class="footer-links">
                    <li><a href="#" data-i18n="srv_merchant">Merchant Management</a></li>
                    <li><a href="#" data-i18n="srv_shipping">Shipping Companies</a></li>
                    <li><a href="#" data-i18n="srv_driver">Driver App</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h4 data-i18n="footer_contact">Contact Us</h4>
                <div class="social-icons">
                    <a href="#"><i class="fa-solid fa-circle-info"></i></a>
                    <a href="#"><i class="fa-solid fa-circle-info"></i></a>
                    <a href="#"><i class="fa-solid fa-circle-info"></i></a>
                </div>
            </div>
        </div>
        <div class="footer-bottom">
            <span data-i18n="copyright">Â© 2026 Logistics Platform. All rights reserved.</span>
        </div>
    </footer>

    <script src="~/js/splash.js"></script>
</body>

</html>