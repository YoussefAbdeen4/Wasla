<!DOCTYPE html>
<html lang="@(System.Globalization.CultureInfo.CurrentCulture.TwoLetterISOLanguageName)" dir="ltr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Wasla Admin - @ViewData["Title"]</title>
    <link rel="stylesheet" href="~/style.css" />
    <link rel="stylesheet" href="~/css/admin/admin.css" />
</head>
<body data-theme="wasla">
    <div class="admin-app">
        <!-- ====================== SIDEBAR ====================== -->
        <aside class="admin-sidebar">
            <div class="admin-sidebar-header">
                <a asp-controller="Admin" asp-action="Dashboard" class="admin-logo">
                    <svg viewBox="0 0 24 24" width="28" height="28" fill="currentColor"><path d="M20 8h-3V4H3c-1.1 0-2 .9-2 2v11h2c0 1.66 1.34 3 3 3s3-1.34 3-3h6c0 1.66 1.34 3 3 3s3-1.34 3-3h2v-5l-3-4zM6 18.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm13.5-9l1.96 2.5H17V9.5h2.5zm-1.5 9c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z" /></svg>
                    <span>Wasla Admin</span>
                </a>
            </div>
            <nav class="admin-nav">
                @{
                    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
                }
                <a asp-controller="Admin" asp-action="Dashboard" class="admin-nav-item @(currentAction == "Dashboard" ? "active" : "")">
                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z" /></svg><span>Dashboard</span>
                </a>
                <a asp-controller="Admin" asp-action="Companies" class="admin-nav-item @(currentAction == "Companies" ? "active" : "")">
                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 7V3H2v18h20V7H12zM6 19H4v-2h2v2zm0-4H4v-2h2v2zm0-4H4V9h2v2zm0-4H4V5h2v2zm4 12H8v-2h2v2zm0-4H8v-2h2v2zm0-4H8V9h2v2zm0-4H8V5h2v2zm10 12h-8v-2h2v-2h-2v-2h2v-2h-2V9h8v10zm-2-8h-2v2h2v-2zm0 4h-2v2h2v-2z" /></svg><span>Shipping Companies</span>
                </a>
                <a asp-controller="Admin" asp-action="Merchants" class="admin-nav-item @(currentAction == "Merchants" ? "active" : "")">
                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20 6h-4V4c0-1.11-.89-2-2-2h-4c-1.11 0-2 .89-2 2v2H4c-1.11 0-1.99.89-1.99 2L2 19c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V8c0-1.11-.89-2-2-2zm-6 0h-4V4h4v2z" /></svg><span>Merchants</span>
                </a>
                <a asp-controller="Admin" asp-action="Orders" class="admin-nav-item @(currentAction == "Orders" ? "active" : "")">
                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-9 14l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" /></svg><span>Orders</span>
                </a>
                <a asp-controller="Admin" asp-action="Drivers" class="admin-nav-item @(currentAction == "Drivers" ? "active" : "")">
                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.92 6.01C18.72 5.42 18.16 5 17.5 5h-11c-.66 0-1.21.42-1.42 1.01L3 12v8c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-1h12v1c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-8l-2.08-5.99zM6.5 16c-.83 0-1.5-.67-1.5-1.5S5.67 13 6.5 13s1.5.67 1.5 1.5S7.33 16 6.5 16zm11 0c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zM5 11l1.5-4.5h11L19 11H5z" /></svg><span>Delivery Reps</span>
                </a>
                @* <a asp-controller="Admin" asp-action="Pricing" class="admin-nav-item @(currentAction == "Pricing" ? "active" : "")">
                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z" /></svg><span>Pricing Packages</span>
                </a>
                <a asp-controller="Admin" asp-action="Settings" class="admin-nav-item @(currentAction == "Settings" ? "active" : "")">
                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.06-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.73 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.06.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .43-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.49-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z" /></svg><span>Settings</span>
                </a> *@
            </nav>
            <div class="company-sidebar-footer">
                <form asp-controller="Auth" asp-action="Logout" method="post" style="display:inline;">
                    <button type="submit" class="company-nav-item company-logout-btn" style="border:none;background:none;padding:0;">
                        <i class="fa-solid fa-right-from-bracket"></i>
                        <span data-i18n="logout">تسجيل الخروج</span>
                    </button>
                </form>
            </div>
        </aside>

        <!-- ====================== MAIN WRAPPER ====================== -->
        <div class="admin-main-wrapper">
            <header class="admin-header">
                <div class="admin-header-left">
                    <button class="admin-toggle-btn" id="admin-sidebar-toggle">
                        <svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor"><path d="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z" /></svg>
                    </button>
                    <h2 class="admin-page-title">@ViewData["Title"]</h2>
                </div>
                <div class="admin-header-right">
                    <div style="display:flex; gap:0.25rem; background:var(--admin-bg); padding:0.25rem; border-radius:60px;">
                        <button class="lang-btn" data-lang="en">EN</button>
                        <button class="lang-btn" data-lang="ar">AR</button>
                    </div>
                    <div class="admin-user-profile">
                        <div class="admin-user-info" style="text-align: end;">
                            <span class="admin-user-name">@User.Identity?.Name</span>
                            <span class="admin-user-role">System Admin</span>
                        </div>
                        <div class="admin-avatar">@(User.Identity?.Name?.Length > 0 ? User.Identity.Name[0].ToString().ToUpper() : "A")</div>
                    </div>
                </div>
            </header>

            <main class="admin-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/js/admin/admin.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>