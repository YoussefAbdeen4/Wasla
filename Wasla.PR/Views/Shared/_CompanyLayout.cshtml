@using Microsoft.AspNetCore.Identity
@using Wasla.Models
@using Microsoft.EntityFrameworkCore
@inject UserManager<ApplicationUser> UserManager
@inject AppDbContext Context

@{
    // قيم افتراضية لمنع أي خطأ NullReference
    string companyName = "شركة غير محددة";
    string ownerName = "مستخدم";
    char avatarLetter = '؟';

    // التحقق من حالة تسجيل الدخول
    bool isAuthenticated = User.Identity?.IsAuthenticated ?? false;

    if (isAuthenticated)
    {
        var user = await UserManager.GetUserAsync(User);
        if (user != null)
        {
            var company = await Context.CourierCompanies.FirstOrDefaultAsync(x => x.UserId == user.Id);
            
            if (company != null)
            {
                companyName = company.CompanyName ?? "اسم الشركة";
                ownerName = company.Name ?? "اسم المستخدم";
                avatarLetter = !string.IsNullOrEmpty(companyName) ? companyName[0] : '؟';
            }
        }
    }
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title data-i18n="dashboard">@ViewData["Company_Title"] - وصلة</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <link rel="stylesheet" href="~/css/company/style.css">
</head>
<body>
    <div class="company-app">
        <!-- القائمة الجانبية -->
        @if (isAuthenticated)
        {
            <aside class="company-sidebar">
                <div class="company-sidebar-header">
                    <a href="#" class="company-logo">
                        <i class="fa-solid fa-truck-fast"></i>
                        <span data-i18n="company_name">@companyName</span>
                    </a>
                </div>
                <nav class="company-sidebar-nav">
                    <a asp-controller="Company" asp-action="Index" class="company-nav-item"><i class="fa-solid fa-chart-pie"></i> <span data-i18n="dashboard">لوحة التحكم</span></a>
                    <a asp-controller="Company" asp-action="Profile" class="company-nav-item"><i class="fa-solid fa-building"></i> <span data-i18n="profile">بيانات حساب الشركة</span></a>
                    <a asp-controller="CompanyAgent" asp-action="Index" class="company-nav-item"><i class="fa-solid fa-users"></i> <span data-i18n="delegates">المناديب</span></a>
                    <a asp-controller="CompanyRateCard" asp-action="Index" class="company-nav-item"><i class="fa-solid fa-tag"></i> <span>البطاقات السعرية</span></a>
                    <a asp-controller="Company" asp-action="Orders" class="company-nav-item"><i class="fa-solid fa-box"></i> <span data-i18n="orders">الطلبات</span></a>
                    <a asp-controller="Company" asp-action="Financials" class="company-nav-item"><i class="fa-solid fa-wallet"></i> <span data-i18n="financials">الإدارة المالية</span></a>
                </nav>
                <div class="company-sidebar-footer">
                    <form asp-controller="Auth" asp-action="Logout" method="post" style="display:inline;">
                        <button type="submit" class="company-nav-item company-logout-btn" style="border:none;background:none;padding:0;">
                            <i class="fa-solid fa-right-from-bracket"></i>
                            <span data-i18n="logout">تسجيل الخروج</span>
                        </button>
                    </form>
                </div>
            </aside>
        }

        <!-- المحتوى الرئيسي -->
        <main class="company-main-wrapper">
            @if (isAuthenticated)
            {
                <header class="company-header">
                    <div class="company-header-left">
                        <button class="company-toggle-btn"><i class="fa-solid fa-bars"></i></button>
                        <h1 class="company-page-title" data-i18n="dashboard">لوحة التحكم</h1>
                    </div>
                    <div class="company-header-right">
                        <div class="company-lang-switcher">
                            <button class="company-lang-btn" data-lang="en">EN</button>
                            <button class="company-lang-btn active" data-lang="ar">AR</button>
                        </div>
                        <div class="company-user-profile">
                            <div class="company-user-info">
                                <span class="company-user-name">@companyName</span>
                                <span class="company-user-role"> @ownerName</span>
                            </div>
                            <div class="company-avatar">@avatarLetter</div>
                        </div>
                    </div>
                </header>
            }

            <!-- TempData Alerts -->
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert" style="margin: 20px;">
                    @TempData["Success"]
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert" style="margin: 20px;">
                    @TempData["Error"]
                </div>
            }

            @RenderBody()
        </main>
    </div>

    <script src="~/js/company/script.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>