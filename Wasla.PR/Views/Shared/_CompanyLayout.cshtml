    <title data-i18n="dashboard">لوحة التحكم - وصلة</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="company-app">
        <!-- القائمة الجانبية -->
        <aside class="company-sidebar">
            <div class="company-sidebar-header">
                <a href="index.html" class="company-logo">
                    <i class="fa-solid fa-truck-fast"></i>
                    <span data-i18n="company_name">شركة الشحن السريع</span>
                </a>
            </div>
            <nav class="company-sidebar-nav">
                <a href="index.html" class="company-nav-item active"><i class="fa-solid fa-chart-pie"></i> <span data-i18n="dashboard">لوحة التحكم</span></a>
                <a href="profile.html" class="company-nav-item"><i class="fa-solid fa-building"></i> <span data-i18n="profile">بروفايل الشركة</span></a>
                <a href="delegates.html" class="company-nav-item"><i class="fa-solid fa-users"></i> <span data-i18n="delegates">المناديب</span></a>
                <a href="orders.html" class="company-nav-item"><i class="fa-solid fa-box"></i> <span data-i18n="orders">الطلبات</span></a>
                <a href="financials.html" class="company-nav-item"><i class="fa-solid fa-wallet"></i> <span data-i18n="financials">الإدارة المالية</span></a>
            </nav>
            <div class="company-sidebar-footer">
                <a href="#" class="company-nav-item company-logout-btn"><i class="fa-solid fa-right-from-bracket"></i> <span data-i18n="logout">تسجيل الخروج</span></a>
            </div>
        </aside>

        <!-- المحتوى الرئيسي -->
        <main class="company-main-wrapper">
            <header class="company-header">
                <div class="company-header-left">
                    <button class="company-toggle-btn"><i class="fa-solid fa-bars"></i></button>
                    <h1 class="company-page-title" data-i18n="dashboard">لوحة التحكم</h1>
                </div>
                <div class="company-header-right">
                    <div class="company-lang-switcher">
                        <button class="company-lang-btn" data-lang="en">EN</button>
                        <button class="company-lang-btn active" data-lang="ar">AR</button>
                    </div>
                    <div class="company-user-profile">
                        <div class="company-user-info">
                            <span class="company-user-name" data-i18n="company_name">شركة الشحن السريع</span>
                            <span class="company-user-role" data-i18n="role">مدير الحساب</span>
                        </div>
                        <div class="company-avatar">ش</div>
