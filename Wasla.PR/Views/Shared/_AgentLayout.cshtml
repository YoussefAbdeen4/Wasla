@* Agent layout - sidebar and top header extracted from AGENT/dashboard.html *@
@{
    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString() ?? "Index";
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title data-i18n="dashboard_title">لوحة تحكم المندوب</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <link rel="stylesheet" href="~/css/style.css" />
    @RenderSection("Head", required: false)
</head>
<body>
    <div class="agent-app">
        <aside class="agent-sidebar">
            <div class="agent-sidebar-header">
                <a href="/Agent" class="agent-logo">
                    <i class="fa-solid fa-truck-fast"></i>
                    <span>وصلة</span>
                </a>
            </div>
            <nav class="agent-nav">
                <a href="/Agent" class="agent-nav-item @(currentAction == "Index" ? "active" : "")">
                    <i class="fa-solid fa-chart-line"></i> <span data-i18n="dashboard">لوحة التحكم</span>
                </a>
                <a href="/Agent/Orders" class="agent-nav-item @(currentAction == "Orders" ? "active" : "")">
                    <i class="fa-solid fa-box"></i> <span data-i18n="my_orders">طلباتي</span>
                </a>
                <a href="/Agent/Financials" class="agent-nav-item @(currentAction == "Financials" ? "active" : "")">
                    <i class="fa-solid fa-wallet"></i> <span data-i18n="my_financials">مالياتي</span>
                </a>
                <a href="/Agent/Profile" class="agent-nav-item @(currentAction == "Profile" ? "active" : "")">
                    <i class="fa-solid fa-user"></i> <span data-i18n="profile">بروفايلي</span>
                </a>
            </nav>
            <div class="agent-sidebar-footer">
                <a href="#" class="agent-nav-item agent-logout">
                    <i class="fa-solid fa-right-from-bracket"></i> <span data-i18n="logout">تسجيل خروج</span>
                </a>
            </div>
        </aside>

        <main class="agent-main">
            <header class="agent-header">
                <div class="agent-header-left">
                    <button class="agent-toggle-btn"><i class="fa-solid fa-bars"></i></button>
                    <a href="/Agent" style="text-decoration: none; color: inherit; cursor: pointer;">
                        <h2 class="agent-page-title" data-i18n="dashboard">لوحة التحكم</h2>
                    </a>
                </div>
                <div class="agent-header-right">
                    <div class="agent-lang-switcher">
                        <button class="agent-lang-btn" data-lang="en">EN</button>
                        <button class="agent-lang-btn" data-lang="ar">AR</button>
                    </div>

                    <a href="/Agent/Profile" class="agent-user-profile" style="text-decoration: none; color: inherit; cursor: pointer;">
                        <div class="agent-user-info">
                            <span class="agent-user-name" id="agentName">مندوب</span>
                            <span class="agent-user-role" data-i18n="role_agent">مندوب توصيل</span>
                        </div>
                        <div class="agent-avatar" id="agentAvatar">م</div>
                    </a>
                </div>
            </header>

            <div class="agent-content">
                @RenderBody()
            </div>
        </main>
    </div>

    <script src="~/js/agent.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>