@{
}

@model IEnumerable<Wasla.PR.Models.ViewModels.Agent.AgentOrderViewModel>

<div class="agent-card">
    <div class="agent-card-header">
        <h3 class="agent-card-title"><i class="fa-solid fa-list"></i> <span data-i18n="all_orders">جميع طلباتي</span></h3>
    </div>
    <div class="agent-table-container">
        <table class="agent-table" id="agentOrdersTable">
            <thead>
                <tr>
                    <th data-i18n="order_no">رقم الطلب</th>
                    <th data-i18n="customer">العميل</th>
                    <th data-i18n="amount">المبلغ</th>
                    <th data-i18n="status">الحالة</th>
                    <th data-i18n="actions">الإجراءات</th>
                </tr>
            </thead>
            <tbody id="agentOrdersBody">
                @if (Model == null || !Model.Any())
                {
                    <tr><td colspan="5" style="text-align:center;">@Html.Raw("<span data-i18n=\"no_data\">لا توجد بيانات</span>")</td></tr>
                }
                else
                {
                    foreach (var order in Model)
                    {
                        <tr>
                            <td>@order.OrderNumber</td>
                            <td>@order.CustomerName</td>
                            <td>@order.Amount.ToString("F2") E.G</td>
                            <td>@order.Status</td>
                            <td>
                                <div class="agent-actions">
                                    @if (order.CanPickUp)
                                    {
                                        <button class="agent-btn agent-btn-sm agent-pickup" data-order-id="@order.Id"><i class="fa-solid fa-box"></i> <span data-i18n="pick_up">استلام</span></button>
                                    }
                                    @if (order.CanDeliver)
                                    {
                                        <button class="agent-btn agent-btn-sm agent-deliver" data-order-id="@order.Id"><i class="fa-solid fa-truck"></i> <span data-i18n="deliver">تسليم</span></button>
                                    }
                                    @if (order.CanReturn)
                                    {
                                        <button class="agent-btn agent-btn-sm agent-return" data-order-id="@order.Id"><i class="fa-solid fa-undo"></i> <span data-i18n="return_order">إرجاع</span></button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

