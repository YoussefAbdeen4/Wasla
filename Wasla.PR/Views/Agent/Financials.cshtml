@{
}

@model AgentFinancialsViewModel

<div class="agent-stats-grid">
    <div class="agent-stat-card">
        <div class="agent-stat-icon"><i class="fa-solid fa-coins"></i></div>
        <div class="agent-stat-info">
            <span class="agent-stat-label" data-i18n="cash_in_hand">النقدية معي</span>
            <span class="agent-stat-value" id="cashInHand">@Model.CashInHand.ToString("F2") E.G</span>
        </div>
    </div>
    <div class="agent-stat-card">
        <div class="agent-stat-icon"><i class="fa-solid fa-building"></i></div>
        <div class="agent-stat-info">
            <span class="agent-stat-label" data-i18n="cash_delivered">سلمت للشركة</span>
            <span class="agent-stat-value" id="cashDelivered">@Model.CashDelivered.ToString("F2") E.G</span>
        </div>
    </div>
    <div class="agent-stat-card">
        <div class="agent-stat-icon"><i class="fa-solid fa-scale-balanced"></i></div>
        <div class="agent-stat-info">
            <span class="agent-stat-label" data-i18n="balance">الرصيد</span>
            <span class="agent-stat-value" id="balance">@Model.Balance.ToString("F2") E.G</span>
        </div>
    </div>
</div>

<!-- Submit cash form -->
<div class="agent-card">
    <h3 class="agent-card-title"><i class="fa-solid fa-hand-holding-dollar"></i> <span data-i18n="submit_cash">تسليم نقدية للشركة</span></h3>
    <div class="agent-form-group">
        <label class="agent-form-label" data-i18n="amount_egp">المبلغ (E.G)</label>
        <input type="number" id="submitAmount" class="agent-form-control" data-i18n-placeholder="amount_egp" placeholder="أدخل المبلغ">
    </div>
    <button id="submitCashBtn" class="agent-btn agent-btn-primary"><i class="fa-solid fa-money-bill-transfer"></i> <span data-i18n="submit">تسليم</span></button>
</div>

