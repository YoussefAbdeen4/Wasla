@{
    ViewData["Auth_Title"] = "Forgot Password";
}

<div class="container">
    <div class="header-top">
        <a href="../index.html" class="logo-icon" style="text-decoration: none;">
            <i class="fa-solid fa-key"></i>
        </a>
        <h1 class="app-title" data-i18n="forgot_password">Forgot Password</h1>
        <p class="app-subtitle" data-i18n="enter_email_reset">Enter your email address to receive a password reset link.</p>
    </div>

    <div class="card">
        <form id="forgot-password-form">
            <div class="form-group">
                <label class="form-label" data-i18n="email_address">Email Address</label>
                <div class="input-wrapper">
                    <div class="input-icon"><i class="fa-regular fa-envelope"></i></div>
                    <input type="email" name="email" class="form-control has-icon" data-i18n="enter_email" required>
                </div>
            </div>

            <button type="submit" class="btn btn-primary" data-i18n="send_reset_link">Send Reset Link</button>
                
            <p class="footer-text">
                <a href="login.html" class="link" data-i18n="back_to_login">Back to Login</a>
            </p>
        </form>
    </div>
</div>