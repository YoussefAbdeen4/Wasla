@{
    ViewData["Auth_Title"] = "Reset Password";
}

<div class="container">
    <div class="header-top">
        <a href="../index.html" class="logo-icon" style="text-decoration: none;">
            <i class="fa-solid fa-unlock-keyhole"></i>
        </a>
        <h1 class="app-title" data-i18n="reset_password">Reset Your Password</h1>
        <p class="app-subtitle" data-i18n="create_new_secure">Create a new secure password for your account</p>
    </div>

    <div class="card">
        <form id="reset-password-form">
            <div class="form-group">
                <label class="form-label" data-i18n="new_password">New Password</label>
                <div class="input-wrapper">
                    <div class="input-icon"><i class="fa-solid fa-lock"></i></div>
                    <input type="password" name="password" class="form-control has-icon has-toggle" data-i18n="enter_new_password" required>
                    <button type="button" class="toggle-password"><i class="fa-solid fa-eye"></i></button>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label" data-i18n="confirm_new_password">Confirm New Password</label>
                <div class="input-wrapper">
                    <div class="input-icon"><i class="fa-solid fa-lock"></i></div>
                    <input type="password" name="confirmPassword" class="form-control has-icon has-toggle" required>
                    <button type="button" class="toggle-password"><i class="fa-solid fa-eye"></i></button>
                </div>
            </div>

            <div class="password-requirements" style="background:#f9fafb;border-radius:8px;padding:1rem;margin-bottom:1.5rem;font-size:0.75rem;color:var(--text-muted);">
                <div class="pwd-req-title" style="font-weight:600;margin-bottom:0.5rem;" data-i18n="pwd_req_title">Password must contain:</div>
                <ul class="pwd-req-list" style="list-style:none;">
                    <li style="margin-bottom:0.25rem;"><i class="fa-solid fa-check" style="color:var(--success);margin-left:0.5rem;margin-right:0.5rem;"></i> <span data-i18n="pwd_req_1">At least 8 characters</span></li>
                    <li style="margin-bottom:0.25rem;"><i class="fa-solid fa-check" style="color:var(--success);margin-left:0.5rem;margin-right:0.5rem;"></i> <span data-i18n="pwd_req_2">One uppercase letter</span></li>
                    <li><i class="fa-solid fa-check" style="color:var(--success);margin-left:0.5rem;margin-right:0.5rem;"></i> <span data-i18n="pwd_req_3">One number</span></li>
                </ul>
            </div>

            <button type="submit" class="btn btn-primary" data-i18n="reset_btn">Reset Password</button>
        </form>
    </div>
</div>
