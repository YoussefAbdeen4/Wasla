@{
    ViewData["Auth_Title"] = "Complete Register Merchant";
}

<div class="container wide">
    <div class="header-top">
        <a href="../index.html" class="logo-icon" style="text-decoration: none;">
            <i class="fa-solid fa-store"></i>
        </a>
        <h1 class="app-title" data-i18n="complete_store_profile">Complete Your Store Profile</h1>
        <p class="app-subtitle" data-i18n="add_store_details">Add your store details to start managing shipments efficiently</p>
    </div>

    <div class="card">
        <form id="signup-merchant-form">
            <div class="form-group">
                <label class="form-label" data-i18n="store_name">Store Name <span class="required">*</span></label>
                <div class="input-wrapper">
                    <div class="input-icon"><i class="fa-solid fa-store"></i></div>
                    <input type="text" name="storeName" class="form-control has-icon" data-i18n="enter_store_name" required>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label" data-i18n="tax_reg_number">Commercial Register Number <span class="required">*</span></label>
                <div class="input-wrapper">
                    <div class="input-icon"><i class="fa-solid fa-file-invoice"></i></div>
                    <input type="text" name="commercialRegister" class="form-control has-icon" data-i18n="enter_tax_reg" required>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label" data-i18n="product_category">Business Type <span class="required">*</span></label>
                <div class="input-wrapper">
                    <div class="input-icon"><i class="fa-solid fa-tags"></i></div>
                    <select name="businessType" class="form-control has-icon" required>
                        <option value="" disabled selected data-i18n="select_category">Select a category</option>
                        <option value="electronics">Electronics</option>
                        <option value="fashion">Fashion</option>
                        <option value="food">Food</option>
                        <option value="other">Other</option>
                    </select>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label" data-i18n="business_address">Business Address <span style="font-weight:normal;color:var(--text-muted);font-size:0.7rem;" data-i18n="optional_recommended">(Optional)</span></label>
                <div class="input-wrapper">
                    <div class="input-icon"><i class="fa-solid fa-location-dot"></i></div>
                    <input type="text" name="address" class="form-control has-icon" data-i18n="enter_address">
                </div>
            </div>

            <div class="btn-row" style="margin-top: 2rem;">
                <button type="button" class="btn btn-secondary" onclick="window.history.back();" data-i18n="back">Back</button>
                <button type="submit" class="btn btn-primary" data-i18n="finish_registration">Finish Registration ✓</button>
            </div>
        </form>
    </div>
</div>
