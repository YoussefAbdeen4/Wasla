@model Wasla.PR.ViewModels.Company.CompanyProfileViewModel

<section class="company-content">
    <!-- الجزء العلوي: الهيدر (صورة الشركة والاسم) -->
    <div class="company-card company-profile-header">
        <div class="company-profile-info">
            <div class="company-avatar-large"><i class="fa-solid fa-truck-fast"></i></div>
            <div>
                <h2>@Model.CompanyName</h2>
                <p class="company-muted">مدير الحساب: @Model.Name</p>
                <span class="company-badge company-badge-success" data-i18n="active">نشط</span>
            </div>
        </div>
        <a class="company-btn company-btn-primary" asp-controller="Company" asp-action="EditProfile" id="editProfileBtn" data-i18n="edit_profile">تعديل الملف الشخصي</a>
    </div>

    <!-- الشبكة الرئيسية: المعلومات الأساسية + مناطق التوصيل -->
    <div class="company-profile-grid">
        
        <!-- كارد المعلومات الأساسية -->
        <div class="company-card">
            <div class="company-card-header">
                <h3 class="company-card-title" data-i18n="basic_info">المعلومات الأساسية</h3>
            </div>
            <div class="company-card-body">
                <div class="company-info-row">
                    <span class="company-info-label" data-i18n="name">اسم الشركة</span>
                    <span class="company-info-value">@Model.CompanyName</span>
                </div>
                <div class="company-info-row">
                    <span class="company-info-label">اسم المسؤول</span>
                    <span class="company-info-value">@Model.Name</span>
                </div>
                <div class="company-info-row">
                    <span class="company-info-label">رقم الضريبة</span>
                    <span class="company-info-value">@Model.TaxNumber</span>
                </div>
                <div class="company-info-row">
                    <span class="company-info-label" data-i18n="phone">رقم التواصل</span>
                    <span class="company-info-value" dir="ltr">@Model.PhoneNumber</span>
                </div>
                <div class="company-info-row">
                    <span class="company-info-label" data-i18n="email">البريد الإلكتروني</span>
                    <span class="company-info-value">@Model.Email</span>
                </div>
            </div>
        </div>

        <!-- كارد مناطق التوصيل (ديناميكي) -->
        <div class="company-card">
            <div class="company-card-header">
                <h3 class="company-card-title" data-i18n="delivery_zones">مناطق التوصيل</h3>
            </div>
            <div class="company-card-body">
                <div class="company-badges-list" id="profileZones">
                    @if (Model.DeliveryZones != null && Model.DeliveryZones.Any())
                    {
                        @foreach (var zone in Model.DeliveryZones)
                        {
                            <span class="company-badge company-badge-primary">@zone</span>
                        }
                    }
                    else
                    {
                        <span class="company-muted" style="font-size: 0.9rem;">لا توجد مناطق توصيل مسجلة</span>
                    }
                </div>
            </div>
        </div>

    </div>
</section>