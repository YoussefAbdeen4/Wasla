@model Wasla.PR.ViewModels.Company.FinancialsViewModel

<div class="company-content">
    <!-- 3 بطاقات مالية -->
    <div class="company-stats-grid">
        <div class="company-stat-card">
            <div class="company-stat-icon"><i class="fa-solid fa-chart-line"></i></div>
            <div class="company-stat-info">
                <span class="company-stat-label">المتوقع تحصيله</span>
                <span class="company-stat-value">@Model.Summary.ExpectedCollection.ToString("N2") ج.م</span>
            </div>
        </div>
        <div class="company-stat-card">
            <div class="company-stat-icon"><i class="fa-solid fa-hand-holding-dollar"></i></div>
            <div class="company-stat-info">
                <span class="company-stat-label">المسلم للشركة</span>
                <span class="company-stat-value">@Model.Summary.DeliveredToCompany.ToString("N2") ج.م</span>
            </div>
        </div>
        <div class="company-stat-card">
            <div class="company-stat-icon"><i class="fa-solid fa-scale-balanced"></i></div>
            <div class="company-stat-info">
                <span class="company-stat-label">الرصيد الإجمالي</span>
                <span class="company-stat-value">@Model.Summary.TotalBalance.ToString("N2") ج.م</span>
            </div>
        </div>
    </div>

    <!-- جدول سجل التحصيلات -->
    <div class="company-card">
        <div class="company-card-header">
            <h3 class="company-card-title"><i class="fa-solid fa-clock-rotate-left"></i> سجل عمليات التحصيل</h3>
        </div>
        <div class="company-table-container">
            <table class="company-table">
                <thead>
                    <tr>
                        <th>رقم الطلب</th>
                        <th>العميل</th>
                        <th>المبلغ</th>
                        <th>التاريخ</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Transactions != null && Model.Transactions.Any())
                    {
                        @foreach (var item in Model.Transactions)
                        {
                            <tr>
                                <td>@item.OrderNumber</td>
                                <td>@item.CustomerName</td>
                                <td>@item.Amount.ToString("N2") ج.م</td>
                                <td>@item.CreatedAt.ToString("yyyy/MM/dd")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center">لا توجد عمليات مسجلة حالياً.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>