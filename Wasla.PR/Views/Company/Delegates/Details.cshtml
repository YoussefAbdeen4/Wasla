
@{
}

<section class="company-content">
    <div class="company-card">
        <div class="company-delegate-profile">
            <div class="company-delegate-info">
                <img src="https://ui-avatars.com/api/?name=Ziad+Ahmed&background=f0f7ff&color=0061ff" alt="delegate" class="company-delegate-avatar" id="delegateAvatar">
                <div>
                    <h2 class="company-delegate-name" id="delegateName">زياد أحمد</h2>
                    <span class="company-badge company-badge-success" id="delegateStatus"><i class="fa-solid fa-circle"></i> <span data-i18n="active">نشط</span></span>
                </div>
            </div>
            <div class="company-profile-actions">
                <button class="company-btn company-btn-primary" id="editDelegateBtn" data-i18n="edit">تعديل</button>
                <button class="company-btn company-btn-danger" id="deleteDelegateBtn" data-i18n="delete">حذف</button>
            </div>
        </div>
        <div class="company-details-grid">
            <div class="company-detail-card">
                <span class="company-detail-label"><i class="fa-solid fa-phone"></i> <span data-i18n="phone">رقم الهاتف</span></span>
                <h4 class="company-detail-value" id="delegatePhone" dir="ltr">+20 10 1234 5678</h4>
            </div>
            <div class="company-detail-card">
                <span class="company-detail-label"><i class="fa-solid fa-location-dot"></i> <span data-i18n="city">المدينة</span></span>
                <h4 class="company-detail-value" id="delegateCity">القاهرة</h4>
            </div>
            <div class="company-detail-card">
                <span class="company-detail-label"><i class="fa-solid fa-car-side"></i> <span data-i18n="vehicle_type">نوع المركبة</span></span>
                <h4 class="company-detail-value" id="delegateVehicle">سيارة سيدان</h4>
            </div>
            <div class="company-detail-card">
                <span class="company-detail-label"><i class="fa-solid fa-id-card"></i> <span data-i18n="plate_number">رقم اللوحة</span></span>
                <h4 class="company-detail-value" id="delegatePlate">أ ب ج 1234</h4>
            </div>
        </div>
    </div>

    <div class="company-stats-grid">
        <div class="company-stat-card">
            <div class="company-stat-icon warning"><i class="fa-solid fa-clock"></i></div>
            <div class="company-stat-info">
                <span class="company-stat-number" id="delegatePendingCount">29</span>
                <span class="company-stat-label" data-i18n="pending">قيد الانتظار</span>
            </div>
            <div class="company-progress"><div class="company-progress-bar warning" style="width:30%"></div></div>
        </div>
        <div class="company-stat-card">
            <div class="company-stat-icon success"><i class="fa-solid fa-circle-check"></i></div>
            <div class="company-stat-info">
                <span class="company-stat-number" id="delegateCompletedCount">218</span>
                <span class="company-stat-label" data-i18n="completed">مكتمل</span>
            </div>
            <div class="company-progress"><div class="company-progress-bar success" style="width:75%"></div></div>
        </div>
        <div class="company-stat-card">
            <div class="company-stat-icon danger"><i class="fa-solid fa-rotate-left"></i></div>
            <div class="company-stat-info">
                <span class="company-stat-number" id="delegateReturnedCount">34</span>
                <span class="company-stat-label" data-i18n="returned">مرتجع</span>
            </div>
            <div class="company-progress"><div class="company-progress-bar danger" style="width:15%"></div></div>
        </div>
    </div>
</section>