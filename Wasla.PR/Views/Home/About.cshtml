        <div class="team-card reveal fade-up card-hover">
            <div class="team-name-primary" data-i18n="team_name_1_p">Omnia Salah</div>
            <div class="team-name-secondary" data-i18n="team_name_1_s">أمنية صلاح</div>
            <div class="team-role" data-i18n="team_role_1">Frontend & UI/UX + .NET</div>
        </div>
        <div class="team-card reveal fade-up card-hover stagger-1">
            <div class="team-name-primary" data-i18n="team_name_2_p">Doaa Abdel Naser</div>
            <div class="team-name-secondary" data-i18n="team_name_2_s">دعاء عبد الناصر</div>
            <div class="team-role" data-i18n="team_role_2">Frontend & UI/UX + .NET</div>
        </div>
        <div class="team-card reveal fade-up card-hover stagger-2">
            <div class="team-name-primary" data-i18n="team_name_3_p">Mohamed Shady Hassan</div>
            <div class="team-name-secondary" data-i18n="team_name_3_s">محمد شادي حسن</div>
            <div class="team-role" data-i18n="team_role_3">Backend (.NET)</div>
        </div>
        <div class="team-card reveal fade-up card-hover stagger-3">
            <div class="team-name-primary" data-i18n="team_name_4_p">Mustafa Bakri Muhammed</div>
            <div class="team-name-secondary" data-i18n="team_name_4_s">مصطفى بكري محمد</div>
            <div class="team-role" data-i18n="team_role_4">Backend (.NET)</div>
        </div>
        <div class="team-card reveal fade-up card-hover stagger-4">
            <div class="team-name-primary" data-i18n="team_name_5_p">Youssef Abdeen Ramadan</div>
            <div class="team-name-secondary" data-i18n="team_name_5_s">يوسف عابدين رمضان</div>
            <div class="team-role" data-i18n="team_role_5">Backend (.NET)</div>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="section splash-inline-42">
    <h2 class="section-title" data-i18n="cta_title">Together towards a smarter logistics future</h2>
    <p class="section-subtitle splash-inline-43" data-i18n="cta_sub">We believe that technology is the real solution to develop the shipping market.</p>
    <button class="btn btn-primary splash-inline-44" onclick="window.location.href='signup-role.html'" data-i18n="btn_join">Join Us</button>
</section>
