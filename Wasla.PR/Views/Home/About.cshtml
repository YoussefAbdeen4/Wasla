@{
    ViewData["Title"] = "About Us";
}

<!-- Hero Section -->
<header class="section bg-gradient-shift splash-inline-25">
    <h1 class="hero-title reveal fade-up splash-inline-3" data-i18n="about_hero_title">Connecting merchants and shipping companies in one place</h1>
    <p class="hero-subtitle reveal fade-up stagger-1 splash-inline-26" data-i18n="about_hero_sub">A smart logistics platform aiming to facilitate shipping and delivery operations.</p>
    <div class="reveal fade-up stagger-2 splash-inline-27">
        <i class="fa-solid fa-circle-info"></i>
        <i class="fa-solid fa-circle-info"></i>
        <i class="fa-solid fa-circle-info"></i>
    </div>
</header>

<!-- Who We Are -->
<section class="section section-bg">
    <div class="grid-2 splash-inline-29">
        <div class="reveal slide-right splash-inline-30">
            <i class="fa-solid fa-circle-info"></i>
        </div>
        <div class="reveal slide-left">
            <h2 class="section-title splash-inline-32" data-i18n="who_we_are">Who We Are</h2>
            <p data-i18n="who_desc" class="splash-inline-33">We are a leading platform in the logistics sector, aiming to bridge the gap between merchants and shipping companies.</p>
            <ul class="splash-inline-34">
                <li class="splash-inline-35">
                    <i class="fa-solid fa-circle-info"></i>
                    <span data-i18n="who_li_1">Innovative solutions for merchants.</span>
                </li>
                <li class="splash-inline-35">
                    <i class="fa-solid fa-circle-info"></i>
                    <span data-i18n="who_li_2">Complete management for shipping companies.</span>
                </li>
                <li class="splash-inline-37">
                    <i class="fa-solid fa-circle-info"></i>
                    <span data-i18n="who_li_3">Live tracking of all shipments.</span>
                </li>
            </ul>
        </div>
    </div>
</section>

<!-- Vision, Mission, Goal -->
<section class="section splash-inline-38">
    <div class="grid-3">
        <div class="feature-card reveal fade-up card-hover splash-inline-17">
            <div class="feature-icon icon-hover-effect splash-inline-39">
                <i class="fa-solid fa-circle-info"></i>
            </div>
            <h3 class="feature-title splash-inline-40" data-i18n="vision_title">Our Vision</h3>
            <p class="feature-desc" data-i18n="vision_desc">To be the leading logistics platform in the Middle East, providing a reliable and safe environment for shipping.</p>
        </div>
        <div class="feature-card reveal fade-up card-hover stagger-1 splash-inline-17">
            <div class="feature-icon icon-hover-effect splash-inline-39">
                <i class="fa-solid fa-circle-info"></i> <!-- target/mission icon approx -->
            </div>
            <h3 class="feature-title splash-inline-40" data-i18n="mission_title">Our Mission</h3>
            <p class="feature-desc" data-i18n="mission_desc">Providing smart, advanced technical solutions that help manage operations efficiently.</p>
        </div>
        <div class="feature-card reveal fade-up card-hover stagger-2 splash-inline-17">
            <div class="feature-icon icon-hover-effect splash-inline-39">
                <i class="fa-solid fa-circle-info"></i>
            </div>
            <h3 class="feature-title splash-inline-40" data-i18n="goal_title">Our Goal</h3>
            <p class="feature-desc" data-i18n="goal_desc">Reducing shipping costs and accelerating delivery to satisfy all parties.</p>
        </div>
    </div>
</section>

<!-- Why Choose Us -->
<section class="section section-bg">
    <h2 class="section-title reveal fade-up" data-i18n="why_title">Why Choose Us?</h2>
    <p class="section-subtitle reveal fade-up stagger-1" data-i18n="why_sub">We offer integrated services that make shipping operations easy and guaranteed.</p>
    <div class="grid-4">
        <div class="feature-card reveal fade-up card-hover splash-inline-17">
            <div class="feature-icon icon-hover-effect splash-inline-41"><i class="fa-solid fa-circle-info"></i></div>
            <h3 class="feature-title" data-i18n="why_1">Wide Coverage</h3>
        </div>
        <div class="feature-card reveal fade-up card-hover stagger-1 splash-inline-17">
            <div class="feature-icon icon-hover-effect splash-inline-41"><i class="fa-solid fa-circle-info"></i></div>
            <h3 class="feature-title" data-i18n="why_2">Professional Team</h3>
        </div>
        <div class="feature-card reveal fade-up card-hover stagger-2 splash-inline-17">
            <div class="feature-icon icon-hover-effect splash-inline-41"><i class="fa-solid fa-circle-info"></i></div>
            <h3 class="feature-title" data-i18n="why_3">Secure Solutions</h3>
        </div>
        <div class="feature-card reveal fade-up card-hover stagger-3 splash-inline-17">
            <div class="feature-icon icon-hover-effect splash-inline-41"><i class="fa-solid fa-circle-info"></i></div>
            <h3 class="feature-title" data-i18n="why_4">Continuous Support</h3>
        </div>
    </div>
</section>

