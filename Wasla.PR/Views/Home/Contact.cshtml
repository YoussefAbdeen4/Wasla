@{
    ViewData["Title"] = "Contact Us";
}
<!-- Hero Section -->
<header class="hero-blue splash-inline-47">
    <h1 class="hero-title" data-i18n="contact_title">Contact Us</h1>
    <p class="hero-subtitle" data-i18n="contact_sub">
        We are here to help you and answer all your inquiries regarding
        shipping operations.
    </p>
</header>

<!-- Contact Form -->
<section class="section section-bg splash-inline-48">
    <div class="contact-form-container">
        <h3 data-i18n="btn_send" class="splash-inline-49">Send Message</h3>
        <form id="contact-form">
            <div class="grid-2 splash-inline-50">
                <div class="form-group">
                    <label class="form-label" data-i18n="msg_name">Full Name</label>
                    <input type="text" class="form-control" required data-i18n="enter_msg_name"
                           placeholder="Enter your full name">
                </div>
                <div class="form-group">
                    <label class="form-label" data-i18n="msg_phone">Phone Number</label>
                    <input type="tel" class="form-control" required data-i18n="enter_msg_phone"
                           placeholder="Enter your phone number">
                </div>
            </div>

            <div class="grid-2 splash-inline-50">
                <div class="form-group">
                    <label class="form-label" data-i18n="msg_email">Email Address</label>
                    <input type="email" class="form-control" required data-i18n="enter_msg_email"
                           placeholder="Enter your email address">
                </div>
                <div class="form-group">
                    <label class="form-label" data-i18n="msg_type">Message Type</label>
                    <select class="form-control">
                        <option>Inquiry</option>
                        <option>Support</option>
                        <option>Suggestion</option>
                    </select>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label" data-i18n="msg_subject">Message Subject</label>
                <input type="text" class="form-control" required data-i18n="enter_msg_subject"
                       placeholder="e.g., Inquiry about shipping">
            </div>

            <div class="form-group">
                <label class="form-label" data-i18n="msg_details">Message Details</label>
                <textarea class="form-control" rows="5" required data-i18n="enter_msg_details"
                          placeholder="Write your message details here..."></textarea>
            </div>

            <button type="submit" class="btn btn-primary splash-inline-44" data-i18n="btn_send">
                Send
                Message
            </button>
        </form>
    </div>
</section>

<!-- Quick Contact Info -->
<section class="section">
    <h2 class="section-title" data-i18n="contact_info_title">Quick Contact Info</h2>
    <div class="grid-2 splash-inline-51">
        <div class="feature-card splash-inline-17">
            <div class="feature-icon splash-inline-52">
                <i class="fa-solid fa-circle-info"></i>
            </div>
            <h3 class="feature-title" data-i18n="phone_num">Phone Number</h3>
            <p class="feature-desc" data-i18n="phone_desc">Call us to get immediate help.</p>
            <div class="splash-inline-53">+966 50 000 0000</div>
        </div>
        <div class="feature-card splash-inline-17">
            <div class="feature-icon splash-inline-41">
                <i class="fa-solid fa-circle-info"></i>
            </div>
            <h3 class="feature-title" data-i18n="email_address_title">Email</h3>
            <p class="feature-desc" data-i18n="email_desc">Email us and we will reply as soon as possible.</p>
            <div class="splash-inline-53">support@logistics.com</div>
        </div>
    </div>
</section>

<!-- FAQs -->
<section class="section section-bg">
    <h2 class="section-title" data-i18n="faq_title">Frequently Asked Questions</h2>
    <div class="grid-2 splash-inline-51">
        <div class="faq-card bg-light-purple">
            <div class="splash-inline-54"><i class="fa-regular fa-building"></i></div>
            <div>
                <h4 data-i18n="faq_q1" class="splash-inline-55">How do I track my shipments?</h4>
                <p data-i18n="faq_a1" class="splash-inline-56">
                    You can track your shipments directly through your
                    dashboard.
                </p>
            </div>
        </div>
        <div class="faq-card bg-light-orange">
            <div class="splash-inline-57"><i class="fa-solid fa-truck-moving"></i></div>
            <div>
                <h4 data-i18n="faq_q2" class="splash-inline-55">What are the supported payment methods?</h4>
                <p data-i18n="faq_a2" class="splash-inline-56">
                    We support credit cards, bank transfers, and cash on
                    delivery.
                </p>
            </div>
        </div>
        <div class="faq-card bg-light-green">
            <div class="splash-inline-58"><i class="fa-solid fa-box"></i></div>
            <div>
                <h4 data-i18n="faq_q3" class="splash-inline-55">Can I integrate the API with my store?</h4>
                <p data-i18n="faq_a3" class="splash-inline-56">Yes, we provide an easy-to-use API for merchants.</p>
            </div>
        </div>
        <div class="faq-card bg-light-blue">
            <div class="splash-inline-59"><i class="fa-solid fa-money-bill"></i></div>
            <div>
                <h4 data-i18n="faq_q4" class="splash-inline-55">How are delivery prices calculated?</h4>
                <p data-i18n="faq_a4" class="splash-inline-56">
                    Prices are calculated based on weight, distance, and
                    the selected shipping company.
                </p>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="hero-blue splash-inline-60">
    <h2 class="hero-title splash-inline-61" data-i18n="cta2_title">
        Ready to help you improve your shipping
        operations
    </h2>
    <p class="hero-subtitle" data-i18n="cta2_sub">
        Join thousands of companies and merchants managing their
        operations efficiently.
    </p>
    <button class="btn splash-inline-62" onclick="window.location.href='signup-role.html'"
            data-i18n="btn_start_now">
        Start Now
    </button>
</section>

