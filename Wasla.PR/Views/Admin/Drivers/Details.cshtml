@model Wasla.PR.ViewModels.Admin.AdminDriverDetailsViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Driver Details";
}

<div class="admin-page-header">
    <h1 class="admin-page-title">@Model.Name</h1>
    <a href="@Url.Action("Drivers")" class="admin-btn admin-btn-outline">Back to Drivers</a>
</div>

<div class="admin-card">
    <h3 class="admin-card-title">Driver Information</h3>
    <table class="admin-table">
        <tbody>
            <tr><td><strong>Name</strong></td><td>@Model.Name</td></tr>
            <tr><td><strong>Company</strong></td><td>@Model.CompanyName</td></tr>
            <tr><td><strong>Total Cash Submitted</strong></td><td>@Model.TotalCashSubmitted.ToString("N2")</td></tr>
            <tr>
                <td><strong>Phones</strong></td>
                <td>@string.Join(", ", Model.Phones)</td>
            </tr>
            <tr>
                <td><strong>Status</strong></td>
                <td>
                    @if (Model.Status == "Active")
                    {
                        <span class="admin-badge admin-badge-success">Active</span>
                    }
                    else
                    {
                        <span class="admin-badge admin-badge-danger">Suspended</span>
                    }
                </td>
            </tr>
        </tbody>
    </table>
</div>

<div class="admin-stats-grid">
    <div class="admin-stat-card">
        <div class="admin-stat-info">
            <div class="admin-stat-label">Orders</div>
            <div class="admin-stat-value">@Model.OrdersCount</div>
        </div>
    </div>
    <div class="admin-stat-card">
        <div class="admin-stat-info">
            <div class="admin-stat-label">Vehicles</div>
            <div class="admin-stat-value">@Model.VehiclesCount</div>
        </div>
    </div>
</div>