@model Wasla.PR.ViewModels.Admin.AdminCompaniesListViewModel
@{
    Layout="~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Shipping Companies";
}

<div class="admin-page-header">
    <h1 class="admin-page-title">Shipping Companies</h1>
</div>

<div class="admin-card">
    <div class="admin-table-container">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Phone</th>
                    <th>Orders</th>
                    <th>Status</th>
                    
                </tr>
            </thead>
            <tbody>
                @foreach (var company in Model.Companies)
                {
                    <tr>
                        <td><strong>@company.Name</strong></td>
                        <td>@company.Contact</td>
                        <td>@company.OrdersCount</td>
                        <td>
                            @if (company.Status == "Active")
                            {
                                <span class="admin-badge admin-badge-success">Active</span>
                            }
                            else
                            {
                                <span class="admin-badge admin-badge-danger">Suspended</span>
                            }
                        </td>
                        
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>