@model Wasla.PR.ViewModels.Admin.AdminMerchantDetailsViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Merchant Details";
}

<div class="admin-page-header">
    <h1 class="admin-page-title">@Model.StoreName</h1>
    <a href="@Url.Action("Merchants")" class="admin-btn admin-btn-outline">Back to Merchants</a>
</div>

<div class="admin-card">
    <h3 class="admin-card-title">Merchant Information</h3>
    <table class="admin-table">
        <tbody>
            <tr><td><strong>Owner Name</strong></td><td>@Model.Name</td></tr>
            <tr><td><strong>Store Name</strong></td><td>@Model.StoreName</td></tr>
            <tr><td><strong>Category</strong></td><td>@Model.Category</td></tr>
            <tr><td><strong>Tax Number</strong></td><td>@Model.TaxNumber</td></tr>
            <tr><td><strong>Wallet Balance</strong></td><td>@Model.WalletBalance.ToString("N2")</td></tr>
            <tr>
                <td><strong>Phones</strong></td>
                <td>@string.Join(", ", Model.Phones)</td>
            </tr>
            <tr>
                <td><strong>Status</strong></td>
                <td>
                    @if (Model.Status == "Active")
                    {
                        <span class="admin-badge admin-badge-success">Active</span>
                    }
                    else
                    {
                        <span class="admin-badge admin-badge-danger">Suspended</span>
                    }
                </td>
            </tr>
        </tbody>
    </table>
</div>

<div class="admin-stats-grid">
    <div class="admin-stat-card">
        <div class="admin-stat-info">
            <div class="admin-stat-label">Orders</div>
            <div class="admin-stat-value">@Model.OrdersCount</div>
        </div>
    </div>
    <div class="admin-stat-card">
        <div class="admin-stat-info">
            <div class="admin-stat-label">Ratings</div>
            <div class="admin-stat-value">@Model.RatingsCount</div>
        </div>
    </div>
    <div class="admin-stat-card">
        <div class="admin-stat-info">
            <div class="admin-stat-label">Clients</div>
            <div class="admin-stat-value">@Model.ClientsCount</div>
        </div>
    </div>
</div>